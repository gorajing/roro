{
  "name": "roro",
  "productName": "Roro",
  "version": "1.0.0",
  "description": "A private local coding companion that remembers how you work.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "release:doctor": "tsx scripts/verify-signing-readiness.ts --allow-unsigned",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:brain": "tsx src/brain/eval/runEval.ts",
    "eval:trace-review": "tsx src/brain/eval/cohortTraceReviewCli.ts",
    "verify:floating": "node scripts/smoke-floating-ask.mjs",
    "verify:floating-live-turn": "node scripts/smoke-floating-live-turn.mjs",
    "verify:typed-live-turn": "node scripts/smoke-typed-live-turn.mjs",
    "verify:memory-panel-rendered": "node scripts/smoke-memory-panel-rendered.mjs",
    "verify:epipe": "node scripts/smoke-packaged-epipe.mjs",
    "verify:packaged-memory": "node scripts/smoke-packaged-memory.mjs",
    "verify:packaged-memory-health": "node scripts/smoke-packaged-memory-health.mjs",
    "verify:packaged-live-memory-turn": "RORO_PACKAGED_MEMORY_LIVE_TURN=1 node scripts/smoke-packaged-memory.mjs",
    "verify:packaged-natural-memory-turn": "RORO_PACKAGED_MEMORY_NATURAL_LANGUAGE_TURN=1 node scripts/smoke-packaged-memory.mjs",
    "verify:packaged-onboarding": "node scripts/smoke-packaged-onboarding.mjs",
    "verify:release-artifact": "node scripts/verify-release-artifact.mjs --mode default",
    "verify:release-artifact:dmg": "node scripts/verify-release-artifact.mjs --mode default --require-dmg",
    "verify:release-artifact:signed": "node scripts/verify-release-artifact.mjs --mode signed",
    "verify:signing-readiness": "tsx scripts/verify-signing-readiness.ts",
    "verify:signing-auth": "tsx scripts/verify-signing-readiness.ts --check-notary-auth",
    "stage:voice-assets": "node scripts/stage-voice-assets.mjs",
    "prestart": "node scripts/stage-voice-assets.mjs",
    "prepackage": "node scripts/stage-voice-assets.mjs",
    "premake": "node scripts/stage-voice-assets.mjs"
  },
  "keywords": [],
  "author": {
    "name": "Jin Choi",
    "email": "jinchoi@u.northwestern.edu"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/asar": "^3.4.1",
    "@electron/fuses": "^1.8.0",
    "@electron/notarize": "^2.5.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "42.4.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.22.4",
    "typescript": "~5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@electric-sql/pglite-pgvector": "^0.0.4",
    "@huggingface/transformers": "^3.8.1",
    "@pixi/unsafe-eval": "^7.4.3",
    "@ricky0123/vad-web": "^0.0.30",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "openai": "^6.44.0",
    "phonemize": "1.2.0",
    "pixi-live2d-display-lipsyncpatch": "^0.5.0-ls-8",
    "pixi.js": "^7.4.3",
    "sharp": "^0.35.1",
    "yaml": "^2.9.0"
  }
}
