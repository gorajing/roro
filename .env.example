# Roro is LOCAL-FIRST: with no .env at all, it runs on a local Ollama brain + local PGlite
# memory and makes no network calls. Copy this file to .env only to tune models or opt into
# cloud / voice. NEVER commit a real .env (it is gitignored) — fill in your own values.

# --- Brain (default: local Ollama) ---
BRAIN_PROVIDER=ollama                 # 'ollama' (local, default) or 'nebius' (cloud escape hatch)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b               # reasoning
OLLAMA_VISION_MODEL=qwen2.5vl:7b      # vision (needs substantial RAM)
OLLAMA_EMBED_MODEL=nomic-embed-text   # embeddings
OLLAMA_EMBED_DIM=768                  # set if OLLAMA_EMBED_MODEL is not 768-dim

# --- Nebius (ONLY used when BRAIN_PROVIDER=nebius) ---
NEBIUS_API_KEY=
NEBIUS_MODEL=deepseek-ai/DeepSeek-V3.2
NEBIUS_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
NEBIUS_EMBED_MODEL=Qwen/Qwen3-Embedding-8B

# --- Executor ---
RORO_WORKDIR=/abs/path/to/scratch-git-repo   # the repo the agent codes in (default: cwd)
ANTHROPIC_API_KEY=                            # optional, only for the Claude executor
# RORO_CODEX_BIN=                             # optional override for the codex binary path
# RORO_CLAUDE_BIN=                            # optional override for the claude binary path

# --- Memory (local PGlite; no external DB) ---
# RORO_DB_DIR=                                # override the on-disk memory dir (default: userData/memory)

# --- Voice (on-device; opt-in via dev flags, no keys) ---
# Voice runs fully on-device (Silero VAD + whisper STT + Kokoro TTS). It is gated behind
# RORO_VAD_VOICE / RORO_STT_VOICE / RORO_TTS_VOICE (default off) — there is no cloud key.

# --- Dev/debug ---
# RORO_FLOATING_WINDOW=1                      # transparent frameless floating-cat mode
# RORO_DEBUG_PORT=9223                        # Chromium remote-debugging port (CDP / npm run verify:floating)
