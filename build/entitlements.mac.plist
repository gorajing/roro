<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Chromium/V8 JIT-compiles JS at runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- V8 + on-device WASM (PGlite in MAIN) write+execute memory the hardened runtime
       would otherwise forbid. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- sharp bundles third-party native libvips dylibs (loaded via dlopen). Library validation would
       reject them under the hardened runtime; disabling it lets our re-signed native modules load. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- NO audio-input entitlement: nothing app-side touches the microphone — the on-device voice stack
       (the only mic consumer) was extracted to packages/voice. Re-add com.apple.security.device.audio-input
       here AND NSMicrophoneUsageDescription in forge.config.ts extendInfo together when voice
       re-integrates (both are required or a signed build crashes on first mic access). -->
</dict>
</plist>
