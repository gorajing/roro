{
  "ignorePatterns": ["packages/"],
  "env": {
    "browser": true,
    "es6": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/eslint-recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:import/recommended",
    "plugin:import/electron",
    "plugin:import/typescript"
  ],
  "parser": "@typescript-eslint/parser",
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      "rules": {
        "@typescript-eslint/no-empty-function": "off"
      }
    },
    {
      "files": [
        "src/core/**/*.ts",
        "src/executor/**/*.ts",
        "src/brain/**/*.ts",
        "src/memory2/**/*.ts",
        "src/vision/**/*.ts",
        "src/ambient/**/*.ts"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              { "name": "electron", "message": "The core is Electron-free — reach the platform through a port (src/core/ports)." }
            ],
            "patterns": [
              { "group": ["electron/*"], "message": "The core is Electron-free — reach the platform through a port (src/core/ports)." }
            ]
          }
        ]
      }
    }
  ]
}
